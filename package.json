{
  "name": "manual-finder",
  "private": true,
  "version": "1.8.1",
  "type": "module",
  "description": "iPad専用・完全オフラインのPDFマニュアル検索PWA（外部通信ゼロ）",
  "license": "MIT",
  "scripts": {
    "prepare-assets": "node scripts/copy-pdfjs-assets.mjs && node scripts/copy-ocr-assets.mjs && node scripts/gen-icons.mjs",
    "predev": "npm run prepare-assets",
    "dev": "vite",
    "prebuild": "npm run prepare-assets",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit false --pretty false"
  },
  "dependencies": {
    "dexie": "4.4.4",
    "dexie-react-hooks": "4.4.0",
    "fflate": "0.8.3",
    "minisearch": "7.2.0",
    "pdfjs-dist": "6.1.200",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.4",
    "typescript": "5.6.3",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "1.3.0"
  }
}
